# ── Base de données ──
# En local : localhost / En prod : IP fournie par gcloud-setup.sh
DB_HOST=localhost
DB_DATABASE=spotgourmand
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_strong_password_123
DB_SSL=false
# En production Google Cloud, mets DB_SSL=true

# ── Cloud SQL (fourni par gcloud-setup.sh) ──
DB_CONNECTION_NAME=

# ── JWT ──
JWT_SECRET=CHANGE_ME_random_secret_key_64chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=CHANGE_ME_another_random_secret_key_64chars
JWT_REFRESH_EXPIRATION=7d

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── URLs ──
# FRONTEND_URL : URL complète du frontend (utilisée par le backend pour CORS + redirections OAuth)
FRONTEND_URL=http://localhost
# VITE_API_URL : URL de BASE du backend AVEC le suffixe /api (baked in lors du build Docker du frontend)
VITE_API_URL=http://localhost:3000/api

# ── Google Cloud (pour le déploiement) ──
GCLOUD_PROJECT=my-first-project
GCLOUD_REGION=europe-west1

# ── Google OAuth (optionnel) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
